//@version=6
indicator('Portafoglio con Ribilanciamento a Soglia', overlay = false)

// Parametri del portafoglio
initial_balance = input.float(1000, title = 'Saldo iniziale (USD)')
deviation_threshold = input.float(5.0, title = 'Soglia di scostamento (%)', minval = 0.1, tooltip = 'Ribilancia quando la differenza tra peso reale e target supera questa percentuale (es. 5%)') / 100
var start_date = input.time(timestamp('2021-01-01'), title = 'Data di inizio')

// Asset portafoglio
asset1 = input.symbol('BINANCE:BNBUSD', '#1', inline="01", group = 'Assets')
alloc1 = input.float(50, 'Allocazione (%)', group = 'Assets', inline="01", minval = 0, maxval = 100) / 100
color1 = input.color( #F57C00, group = 'Assets', inline="01")
float value1 = na

asset2 = input.symbol('BINANCE:PAXGUSD', '#2', inline="02", group = 'Assets')
alloc2 = input.float(0, 'Allocazione (%)', group = 'Assets', inline="02", minval = 0, maxval = 100) / 100
color2 = input.color( #FBC02D, group = 'Assets', inline="02")
float value2 = na

asset3 = input.symbol('BINANCE:ETHUSD', '#3', inline="03", group = 'Assets')
alloc3 = input.float(50, 'Allocazione (%)', group = 'Assets', inline="03", minval = 0, maxval = 100) / 100
color3 = input.color( #303F9F, group = 'Assets', inline="03")
float value3 = na

asset4 = input.symbol('BINANCE:INJUSD', '#4', inline="04", group = 'Assets')
alloc4 = input.float(0, 'Allocazione (%)', group = 'Assets', inline="04", minval = 0, maxval = 100) / 100
color4 = input.color( #0288D1, group = 'Assets', inline="04")
float value4 = na

asset5 = input.symbol('', '#5', inline="05", group = 'Assets')
alloc5 = input.float(0, 'Allocazione (%)', group = 'Assets', inline="05", minval = 0, maxval = 100) / 100
color5 = input.color( #02c0d1, group = 'Assets', inline="05")
float value5 = na

float portfolio_value = na

// Check if the current bar's timestamp is after the start_date
if time >= start_date

    assets_array = array.from(asset1, asset2, asset3, asset4, asset5)
    alloc_array = array.from(alloc1, alloc2, alloc3, alloc4, alloc5)

    close_array = array.new<float>(0)
    for [index, asset] in assets_array
        asset_close = request.security(asset, timeframe.period, close)
        if na(asset_close)
            asset_close := 0
        array.push(close_array, asset_close)

    // Inizializzazione del portafoglio alla prima barra utile
    var array<float> amount_array = na
    if na(amount_array)
        amount_array := array.new<float>(0)
        for [index, asset_alloc_perc] in alloc_array
            asset_close = close_array.get(index)
            amount = .0        
            if asset_close > .0
                amount := initial_balance * asset_alloc_perc / asset_close
            array.push(amount_array, amount)

    // Calcolo del valore corrente del portafoglio
    portfolio_value := 0
    for [index, asset_amount] in amount_array
        asset_close = close_array.get(index)
        if asset_close > .0
            asset_value = asset_amount * asset_close
            portfolio_value := portfolio_value + asset_value

    // Controllo dello scostamento rispetto ai pesi target
    bool trigger_rebalance = false
    if portfolio_value > 0
        for [index, asset_amount] in amount_array
            asset_close = close_array.get(index)
            target_alloc = alloc_array.get(index)
            
            // Calcolo del peso effettivo corrente dell'asset nel portafoglio
            float current_alloc = 0.0
            if asset_close > 0.0
                current_alloc := (asset_amount * asset_close) / portfolio_value
                
            // Se lo scostamento assoluto supera la soglia, attiva il flag
            if math.abs(current_alloc - target_alloc) > deviation_threshold
                trigger_rebalance := true
                break

    // Ribilanciamento basato sulla soglia di scostamento
    if trigger_rebalance
        line.new(bar_index, 0, bar_index, close, extend = extend.both, color = color.red, style = line.style_dashed)
        before = amount_array
        debug_infos = '\n--- Ribilanciamento per scostamento ---\n'
        amount_array := array.new<float>(0)
        
        for [index, value] in alloc_array
            asset = assets_array.get(index)
            asset_alloc = alloc_array.get(index)
            asset_close = close_array.get(index)
            amount = .0        
            if asset_close > .0            
                amount := portfolio_value * asset_alloc / asset_close
            array.push(amount_array, amount)
            
            old_amount = before.get(index)
            debug_infos += str.tostring(asset) + ' (' + str.tostring(asset_alloc * 100) + '%): ' + str.tostring(old_amount) + ' -> ' + str.tostring(amount) + '\n'
        log.info(debug_infos)

    value1 := close_array.get(0) * amount_array.get(0)
    value2 := close_array.get(1) * amount_array.get(1)
    value3 := close_array.get(2) * amount_array.get(2)
    value4 := close_array.get(3) * amount_array.get(3)
    value5 := close_array.get(4) * amount_array.get(4)

// Visualizzazione
plot(value1 + value2 + value3 + value4 + value5, '#1', color1, style=plot.style_area, trackprice=false, display=display.pane)
plot(value2 + value3 + value4 + value5, '#2', color2, style=plot.style_area, trackprice=false, display=display.pane)
plot(value3 + value4 + value5, '#3', color3, style=plot.style_area, trackprice=false, display=display.pane)
plot(value4 + value5, '#4', color4, style=plot.style_area, trackprice=false, display=display.pane)
plot(value5, '#5', color5, style=plot.style_area, trackprice=false, display=display.pane)

plot(portfolio_value, 'Valore Portafoglio', color = color.green, linewidth = 2)
plot(value1, '#1', color = color1, display = display.data_window)
plot(value2, '#2', color = color2, display = display.data_window)
plot(value3, '#3', color = color3, display = display.data_window)
plot(value4, '#4', color = color4, display = display.data_window)
plot(value5, '#5', color = color5, display = display.data_window)